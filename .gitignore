# ====================================================================
# DeepShield AI - Git Ignore Manifest
# ====================================================================

# Local Databases (Contains password hashes, audit logs, and analysis records)
*.db
*.sqlite
*.sqlite3
deepshield.db
backend/deepshield.db

# User Media Uploads & GradCAM Visualizations
# (We preserve the directory using a .gitkeep file but ignore files inside)
backend/uploads/*
!backend/uploads/.gitkeep

# Environment variables & Sensitive Credentials
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Python Caches & Compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# Frontend Caches & Build Outputs
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
node_modules/

# Logs & Debug dumps
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
dump.rdb

# Operating System Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor Configurations
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
