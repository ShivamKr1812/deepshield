# ====================================================================
# DeepShield AI - Backend Environment Template
# Copy this file to '.env' and populate with your credentials.
# DO NOT commit the '.env' file containing actual keys to git.
# ====================================================================

PROJECT_NAME="DeepShield AI"
API_V1_STR="/api/v1"

# JWT Signing Secret Key
# Change this to a secure random string in production (e.g. openssl rand -hex 32)
SECRET_KEY="supersecretkeyforjwttokensigningdeepshieldai12345!"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deepshield

# Redis / Celery Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
